#!/usr/bin/env bash
# .githooks/pre-commit
set -e

branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$branch" != "main" ]; then
  echo "Pre-commit: not on main branch ($branch). Skipping tests."
  exit 0
fi

echo "Pre-commit: running pytest..."
pytest test.py
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo "Pre-commit: tests failed. Aborting commit."
  exit 1
fi

exit 0